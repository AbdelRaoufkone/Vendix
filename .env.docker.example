# ════════════════════════════════════════════════
#  VENDIX — Variables d'environnement Docker
#  Copier ce fichier : cp .env.docker.example .env
# ════════════════════════════════════════════════

# ── PostgreSQL ───────────────────────────────────
POSTGRES_USER=vendix
POSTGRES_PASSWORD=CHANGE_MOI_EN_PROD
POSTGRES_DB=vendix

# ── Redis ────────────────────────────────────────
REDIS_PASSWORD=CHANGE_MOI_EN_PROD

# ── JWT (obligatoire — chaînes longues et aléatoires) ──
JWT_ACCESS_SECRET=CHANGE_MOI_EN_PROD_une_chaine_longue_et_aleatoire
JWT_REFRESH_SECRET=CHANGE_MOI_EN_PROD_une_autre_chaine_differente

# ── URLs ─────────────────────────────────────────
FRONTEND_URL=http://localhost
NEXT_PUBLIC_API_URL=http://localhost/api

# Port Nginx (8080 par défaut, si 80 est pris)
HTTP_PORT=8080

# ── Images ───────────────────────────────────────
# Stockées en base64 dans PostgreSQL (compressées ~80KB côté client)
# Aucun service externe nécessaire

# ── Email SMTP (optionnel — reçus par email) ─────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
